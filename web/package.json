import Header from "./components/Header";
import SectionHero from "./components/SectionHero";
import SectionFeatures from "./components/SectionFeatures";
import SectionCTA from "./components/SectionCTA";
import Footer from "./components/Footer";

function App() {
  const features = [
    { icon: "💡", title: "Innovative", description: "Creative solutions for your business." },
    { icon: "⚡", title: "Fast", description: "Optimized for speed and performance." },
    { icon: "🔒", title: "Secure", description: "Safe and reliable services." },
  ];

  return (
    <div>
      <Header />
      <SectionHero
        title="Welcome to Our Website"
        subtitle="We provide awesome services"
        buttonText="Get Started"
      />
      <SectionFeatures features={features} />
      <SectionCTA text="Ready to get started?" buttonText="Sign Up Now" />
      <Footer />
    </div>
  );
}

export default App;